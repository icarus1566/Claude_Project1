# App Config
PROJECT_NAME="lfnovo On-prem RAG"
API_V1_STR="/api/v1"

# Ollama Setting
OLLAMA_BASE_URL="http://ollama:11434"
LLM_MODEL="llama3.1:8b"

# Services
